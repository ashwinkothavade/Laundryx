# Copy this file to .env and fill in the values before `docker compose up`.
# docker compose automatically loads variables from a root .env file.

# ---- General ----
# Use 'development' locally (http). Set to 'production' only behind HTTPS,
# otherwise the Secure auth cookies will be dropped by the browser.
NODE_ENV=development

# ---- Backend ----
# Leave MONGO_URI unset to use the bundled mongo service
# (mongodb://mongo:27017/laundrix). Override to point at MongoDB Atlas.
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/laundrix
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-another-long-random-string

# Origins allowed by CORS / links generated by the backend.
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:4000

# Password-reset email (Gmail app password). Optional for basic usage.
GMAIL_ADDRESS=
GMAIL_PASSWORD=

# Razorpay payment gateway (server side).
# NOTE: the backend instantiates the Razorpay client at startup, so these must
# be non-empty for the server to boot. The dummy values below let the stack
# start for local development; replace with real keys to process payments.
RAZORPAY_KEY_ID=rzp_test_dummy
RAZORPAY_SECRET=dummysecret

# ---- Frontend (baked in at build time by Vite) ----
VITE_DEV_ENV=development
VITE_RAZORPAY_KEY_ID=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
